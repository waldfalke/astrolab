{
  "schema_id": "chart_project/chart.v1",
  "description": "Required structure for charts/<chart_id>/chart.yaml",
  "required_top_level_keys": [
    "chart_id",
    "display_name",
    "birth",
    "location",
    "structure"
  ],
  "required_nested_keys": {
    "birth": [
      "local_datetime",
      "timezone",
      "utc_datetime"
    ],
    "location": [
      "latitude",
      "longitude"
    ],
    "structure": [
      "methods_dir",
      "outputs_dir",
      "packs_dir"
    ]
  }
}
